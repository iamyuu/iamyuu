---
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["footer-wrapper", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <!-- Top gradient border -->
  <div
    class="h-px w-full bg-linear-to-r from-transparent via-border/40 to-transparent"
  >
  </div>

  <div class="app-layout py-8 sm:py-10">
    <div
      class="mt-4 flex flex-col items-center justify-between gap-2 sm:flex-row"
    >
      <p class="font-cartograph text-[11px] tracking-wide opacity-35">
        &copy; {currentYear}
        {SITE.author}.
      </p>
      <p class="font-cartograph text-[11px] tracking-wide opacity-30">
        Code open-sourced on <a href="https://github.com/iamyuu/iamyuu">GitHub</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-wrapper {
    position: relative;
    /* Soft gradient descending to bottom */
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--background) 30%, transparent),
      color-mix(in srgb, var(--background) 80%, transparent) 80%
    );
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
  }
</style>
