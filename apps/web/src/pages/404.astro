---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
---

<Layout title={`Not Found | ${SITE.title}`}>
  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <h1 class="text-9xl font-bold text-accent">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="text-lg sm:text-xl opacity-75">
        Seems you've ventured into uncharted territory
      </p>
    </div>
  </main>
</Layout>
